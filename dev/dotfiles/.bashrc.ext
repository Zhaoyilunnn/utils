############################ Tools ##################################
test-proxy() {
    # 1. 定义代理地址
    local proxy_addr="socks5://127.0.0.1:10808"
 
    # 2. 临时设置当前 Shell 的代理变量
    export http_proxy="$proxy_addr"
    export https_proxy="$proxy_addr"

    echo "已在当前窗口设置代理: $proxy_addr"
    echo "正在测试连通性，请稍候..."

    # 3. 使用 curl 测试谷歌（设置 5 秒超时，仅输出状态码和关键连接信息）
    # -w 可以定制输出格式，-o /dev/null 隐藏网页源码
    local http_code=$(curl -s -o /dev/null -w "%{http_code}" --connect-timeout 5 https://www.google.com)

    # 4. 判断结果
    if [ "$http_code" = "200" ]; then
        echo -e "\033[32m[成功]\033[0m 成功连通 Google！响应状态码为: $http_code"
    else
        echo -e "\033[31m[失败]\033[0m 无法连通 Google，状态码或错误为: $http_code"
        echo "请检查代理软件（如 v2ray/xray）是否在 10808 端口正常运行。"
    fi

    # 5. 测试结束后自动清理变量，防止污染后续的终端命令
    unset http_proxy
    unset https_proxy
    echo "已清除当前窗口的临时代理变量。"
}



# sudo apt update
# sudo apt install fzf fd-find xdg-utils
# 世界上最优雅的命令行搜索并打开文件的快捷命令
o() {
    # 1. 如果安装了 fdfind，就用它作为 fzf 的底层搜索引擎（极速、干净）
    if command -v fdfind &> /dev/null; then
        export FZF_DEFAULT_COMMAND='fdfind --type f'
    fi

    # 2. 启动 fzf，配置优雅的 UI：从下往上显示界面、边框、占用 50% 屏幕
    local file
    file=$(fzf --height 50% --layout=reverse --border --prompt="🔍 Search to Open > ")

    # 3. 优雅地判断处理：只有在你选中了文件（没有按 Esc 取消）时才执行
    if [ -n "$file" ]; then
        # 4. 使用默认软件打开文件
        # </dev/null &> /dev/null : 吞噬所有多余的输入输出，保持终端纯净
        # & : 放入后台运行
        xdg-open "$file" </dev/null &> /dev/null &

        # 5. 彻底剥离进程与终端的关系，关掉终端文件依然保持打开
        disown
    fi
}
############################ Tools ##################################
